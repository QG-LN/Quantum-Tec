<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="LoginService">
    <select id="getUserListAll" resultType="UserVO">
        select *
        from userInfo
    </select>
    <select id="getUserExist" resultType="int">
        select user_idx
        from userInfo
        where user_id = #{userID} and user_pw = #{userPW}
    </select>
    <select id="getUserInfo" resultType="UserVO">
        select *
        from userInfo
        where user_idx = #{userIdx}
    </select>

    <insert id="insertUserInfo" parameterType="UserVO">
        insert into userInfo(user_id,user_pw,user_nickname,user_name,user_birth ,user_address,user_address_detail,user_postal,user_email)
        values(#{userID},#{userPW},#{userNickname},#{userName},#{userBirth},#{userAddress},#{userAddressDetail},#{userPostal},#{userEmail})
    </insert>
</mapper>
